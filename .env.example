# Copy this to .env.local for local development
# NEVER commit .env.local to git — it contains your secret token

# Get your Personal Access Token from:
# https://app.asana.com/0/my-apps → Personal access tokens → Create new token
ASANA_PAT=your_asana_personal_access_token_here

# Your Asana workspace GID (already set to altudo.co workspace)
ASANA_WORKSPACE_GID=1115662927527527
